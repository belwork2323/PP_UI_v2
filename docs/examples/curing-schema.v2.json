{
  "schemaVersion": "1.0",
  "schemaType": "CURING",
  "functionality": "CREATE_CURING_FORM",
  "meta": {
    "title": "Curing Form",
    "description": "Motor curing cycle and post curing details"
  },
  "data": {
    "ui": {
      "layout": "accordion",
      "gap": "md",
      "sectionVariant": "card",
      "sectionBorderRadius": "sm",
      "designSystem": {
        "colors": {
          "primary": "#1565C0",
          "primaryLight": "#1976D2",
          "surface": "#F4F6F8",
          "border": "#D5D8DC",
          "text": "#1C2833",
          "textSub": "#5D6D7E"
        },
        "typography": {
          "fontFamily": "'DM Sans', sans-serif"
        },
        "spacing": {
          "xs": 4,
          "sm": 8,
          "md": 12,
          "lg": 16,
          "xl": 24
        },
        "radius": {
          "sm": 4,
          "md": 6,
          "lg": 8
        },
        "icons": {
          "sectionDefault": "description",
          "curing": "thermostat"
        }
      },
      "accordion": {
        "defaultExpanded": true,
        "allowMultipleExpanded": true,
        "expandIcon": "expand_more"
      }
    },
    "context": {
      "motorStage": 1,
      "subDepartmentId": "{{subDepartmentId}}",
      "motorId": "{{motorId}}"
    },
    "sections": [
      {
        "id": "CURING_CYCLES",
        "title": "Curing Cycles",
        "ui": {
          "variant": "card",
          "icon": "thermostat",
          "padding": "md"
        },
        "children": [
          {
            "type": "section",
            "id": "cycle",
            "title": "Cycle {index}",
            "repeat": {
              "defaultCount": 1,
              "min": 1,
              "max": 20,
              "allowAdd": true,
              "allowDelete": true,
              "label": "Cycle {index}"
            },
            "children": [
              {
                "type": "table",
                "id": "CURING_TABLE",
                "rows": {
                  "defaultCount": 10,
                  "allowAdd": true,
                  "allowDelete": true,
                  "autoIncrementKey": "srNo"
                },
                "columns": [
                  {
                    "type": "column",
                    "id": "srNo",
                    "fieldType": "serial",
                    "label": "S.No",
                    "readonly": true
                  },
                  {
                    "type": "column",
                    "id": "TEMPERATURE",
                    "fieldType": "number",
                    "label": "Temperature",
                    "unit": "°C"
                  },
                  {
                    "type": "column",
                    "id": "TIME",
                    "fieldType": "number",
                    "label": "Time",
                    "unit": "min"
                  },
                  {
                    "type": "column",
                    "id": "START_DATE",
                    "fieldType": "date",
                    "label": "Start Date"
                  },
                  {
                    "type": "column",
                    "id": "START_TIME",
                    "fieldType": "time",
                    "label": "Start Time"
                  },
                  {
                    "type": "column",
                    "id": "END_DATE",
                    "fieldType": "date",
                    "label": "End Date"
                  },
                  {
                    "type": "column",
                    "id": "END_TIME",
                    "fieldType": "time",
                    "label": "End Time"
                  },
                  {
                    "type": "column",
                    "id": "PROPELLANT_PRESSURE",
                    "fieldType": "number",
                    "label": "Propellant Pressure",
                    "unit": "bar"
                  },
                  {
                    "type": "column",
                    "id": "HOT_WATER_STATUS",
                    "fieldType": "dropdown",
                    "label": "Status Of Hot Water Circulation",
                    "dataSource": {
                      "type": "static",
                      "options": ["ON", "OFF", "NA"]
                    }
                  }
                ]
              }
            ]
          }
        ]
      },
      {
        "id": "POST_CURING_DETAILS",
        "title": "Section C: Post Curing Details",
        "ui": {
          "variant": "card",
          "padding": "md",
          "direction": "row",
          "wrap": true,
          "gap": "md"
        },
        "children": [
          {
            "type": "field",
            "id": "OTHER_OBSERVATIONS",
            "fieldType": "textarea",
            "label": "Any Other Observations",
            "ui": { "colSpan": { "xs": 12 } }
          },
          {
            "type": "field",
            "id": "VISUAL_OBSERVATION",
            "fieldType": "textarea",
            "label": "Visual Observation Of Cured Motor",
            "ui": { "colSpan": { "xs": 12 } }
          },
          {
            "type": "field",
            "id": "PRESSURE_PLATE_REMOVAL_DATE_TIME",
            "fieldType": "datetime",
            "label": "Date/Time For Removal Of Pressure Plate"
          },
          {
            "type": "field",
            "id": "SHORE_A_HARDNESS",
            "fieldType": "number",
            "label": "Hardness (Shore A)"
          },
          {
            "type": "field",
            "id": "DE_CORING_DISPATCH_DATE_TIME",
            "fieldType": "datetime",
            "label": "Date/Time Of Dispatch For De-coring"
          }
        ]
      },
      {
        "id": "DECORING_DETAILS",
        "title": "Section D: De-coring Details",
        "ui": {
          "variant": "card",
          "padding": "md",
          "direction": "row",
          "wrap": true,
          "gap": "md"
        },
        "children": [
          {
            "type": "field",
            "id": "DECORING_DATE",
            "fieldType": "date",
            "label": "Date Of De-coring"
          },
          {
            "type": "field",
            "id": "BUILDING_NO",
            "fieldType": "textarea",
            "label": "Building No",
            "ui": { "colSpan": { "xs": 12, "sm": 6 } }
          },
          {
            "type": "field",
            "id": "DECORING_LOAD",
            "fieldType": "number",
            "label": "De-coring Load",
            "unit": "kg"
          },
          {
            "type": "field",
            "id": "DECORING_VISUAL_OBSERVATION",
            "fieldType": "file",
            "label": "Visual Observations",
            "ui": { "colSpan": { "xs": 12 } }
          }
        ]
      }
    ]
  }
}
