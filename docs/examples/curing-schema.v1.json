{
  "schemaVersion": "1.0",
  "schemaType": "CURING",
  "functionality": "CREATE_CURING_FORM",
  "data": {
    "layout": {
      "type": "accordion",
      "gap": "md",
      "sectionVariant": "card",
      "accordionConfig": {
        "defaultExpanded": true,
        "allowMultipleExpanded": true,
        "expandIcon": "expand_more"
      }
    },
    "designSystem": {
      "colors": {
        "primary": "#1565C0",
        "primaryLight": "#1976D2",
        "surface": "#F4F6F8",
        "border": "#D5D8DC",
        "text": "#1C2833",
        "textSub": "#5D6D7E",
        "danger": "#C62828",
        "success": "#2E7D32",
        "warn": "#D4AC0D"
      },
      "typography": {
        "fontFamily": "'DM Sans', sans-serif",
        "scale": {
          "xs": "0.68rem",
          "sm": "0.78rem",
          "md": "0.86rem",
          "lg": "0.98rem"
        },
        "label": {
          "size": "xs",
          "weight": 700,
          "transform": "uppercase",
          "letterSpacing": "0.04em"
        }
      },
      "spacing": {
        "xs": 4,
        "sm": 8,
        "md": 12,
        "lg": 16,
        "xl": 24
      },
      "radius": {
        "sm": 7,
        "md": 11,
        "lg": 16
      },
      "icons": {
        "sectionDefault": "description",
        "curing": "thermostat"
      }
    },
    "meta": {
      "title": "Curing Form",
      "description": "Record curing cycles, post-curing observations, and de-coring details."
    },
    "context": {
      "motorStage": 1,
      "subDepartmentId": 111
    },
    "nodes": [
      {
        "id": "CURING_CYCLES",
        "component": "section",
        "label": "Curing Cycles",
        "style": {
          "variant": "card",
          "icon": "thermostat",
          "iconColor": "primary",
          "padding": "md",
          "gap": "md"
        },
        "children": [
          {
            "id": "CURING_CYCLE_TABLE",
            "component": "repeatable",
            "label": "Curing Cycle",
            "behavior": {
              "repeat": {
                "enabled": true,
                "mode": "cycle",
                "min": 1,
                "max": 20,
                "defaultCount": 1,
                "allowAdd": true,
                "allowDelete": true,
                "labelPattern": "Cycle {index}",
                "addLabel": "Add Cycle",
                "deleteLabel": "Remove Cycle"
              }
            },
            "children": [
              {
                "id": "CURING_CYCLE_ROWS",
                "component": "table",
                "behavior": {
                  "table": {
                    "defaultRows": 10,
                    "minRows": 1,
                    "maxRows": 50,
                    "allowAddRow": true,
                    "allowDeleteRow": true,
                    "autoIncrementKey": "srNo"
                  }
                },
                "children": [
                  {
                    "id": "srNo",
                    "component": "column",
                    "fieldType": "autoIncrement",
                    "label": "S.No",
                    "style": {
                      "width": "60px"
                    },
                    "behavior": {
                      "readonly": true
                    }
                  },
                  {
                    "id": "TEMPERATURE",
                    "component": "column",
                    "fieldType": "number",
                    "label": "Temperature",
                    "unit": "°C",
                    "required": true,
                    "validation": {
                      "min": 0,
                      "max": 200
                    },
                    "style": {
                      "width": "100px"
                    }
                  },
                  {
                    "id": "DURATION",
                    "component": "column",
                    "fieldType": "number",
                    "label": "Time",
                    "unit": "min",
                    "required": true,
                    "validation": {
                      "min": 0
                    },
                    "style": {
                      "width": "90px"
                    }
                  },
                  {
                    "id": "START_DATE",
                    "component": "column",
                    "fieldType": "date",
                    "label": "Start Date",
                    "required": true,
                    "style": {
                      "width": "140px"
                    }
                  },
                  {
                    "id": "START_TIME",
                    "component": "column",
                    "fieldType": "time",
                    "label": "Start Time",
                    "required": true,
                    "style": {
                      "width": "110px"
                    }
                  },
                  {
                    "id": "END_DATE",
                    "component": "column",
                    "fieldType": "date",
                    "label": "End Date",
                    "required": true,
                    "style": {
                      "width": "140px"
                    }
                  },
                  {
                    "id": "END_TIME",
                    "component": "column",
                    "fieldType": "time",
                    "label": "End Time",
                    "required": true,
                    "style": {
                      "width": "110px"
                    }
                  },
                  {
                    "id": "PROPELLANT_PRESSURE",
                    "component": "column",
                    "fieldType": "number",
                    "label": "Propellant Pressure",
                    "unit": "bar",
                    "style": {
                      "width": "120px"
                    }
                  },
                  {
                    "id": "HOT_WATER_CIRCULATION_STATUS",
                    "component": "column",
                    "fieldType": "dropdown",
                    "label": "Status Of Hot Water Circulation",
                    "style": {
                      "width": "160px"
                    },
                    "dataSource": {
                      "type": "static",
                      "options": [
                        "ON",
                        "OFF",
                        "NOT_APPLICABLE"
                      ]
                    }
                  }
                ]
              }
            ]
          }
        ]
      },
      {
        "id": "POST_CURING_DETAILS",
        "component": "section",
        "label": "Post Curing Details",
        "style": {
          "variant": "card",
          "padding": "md",
          "gap": "sm"
        },
        "layout": {
          "direction": "row",
          "wrap": true,
          "gap": "md",
          "alignItems": "flex-end"
        },
        "children": [
          {
            "id": "OTHER_OBSERVATIONS",
            "component": "field",
            "fieldType": "textarea",
            "label": "Any Other Observations",
            "style": {
              "colSpan": {
                "xs": 12,
                "sm": 12,
                "md": 12
              },
              "flex": "1 1 100%"
            }
          },
          {
            "id": "VISUAL_OBSERVATION",
            "component": "field",
            "fieldType": "textarea",
            "label": "Visual Observation Of Cured Motor",
            "style": {
              "colSpan": {
                "xs": 12,
                "sm": 12,
                "md": 12
              },
              "flex": "1 1 100%"
            }
          },
          {
            "id": "PRESSURE_PLATE_REMOVAL_DATETIME",
            "component": "field",
            "fieldType": "datetime",
            "label": "Date Time Of Removal Of Pressure Plate",
            "style": {
              "colSpan": {
                "xs": 12,
                "sm": 6,
                "md": 4
              },
              "width": "260px"
            }
          },
          {
            "id": "SHORE_A_HARDNESS",
            "component": "field",
            "fieldType": "number",
            "label": "Hardness (Shore A)",
            "style": {
              "colSpan": {
                "xs": 12,
                "sm": 6,
                "md": 4
              },
              "width": "180px"
            }
          },
          {
            "id": "DISPATCH_FOR_DECORING_DATETIME",
            "component": "field",
            "fieldType": "datetime",
            "label": "Date Time Of Dispatch For De-Coring",
            "style": {
              "colSpan": {
                "xs": 12,
                "sm": 6,
                "md": 4
              },
              "width": "260px"
            }
          }
        ]
      },
      {
        "id": "DECORING_DETAILS",
        "component": "section",
        "label": "De-Coring Details",
        "style": {
          "variant": "card",
          "padding": "md",
          "gap": "sm"
        },
        "layout": {
          "direction": "row",
          "wrap": true,
          "gap": "md",
          "alignItems": "flex-end"
        },
        "children": [
          {
            "id": "DECORING_DATE",
            "component": "field",
            "fieldType": "date",
            "label": "Date Of De-Coring",
            "style": {
              "colSpan": {
                "xs": 12,
                "sm": 6,
                "md": 4
              },
              "width": "200px"
            }
          },
          {
            "id": "BUILDING_NO",
            "component": "field",
            "fieldType": "dropdown",
            "label": "Building No",
            "style": {
              "colSpan": {
                "xs": 12,
                "sm": 6,
                "md": 4
              },
              "width": "200px"
            },
            "dataSource": {
              "type": "api",
              "api": {
                "endpoint": "BUILDING_MASTER",
                "method": "POST",
                "requestBody": {
                  "subDepartmentId": "{{subDepartmentId}}"
                },
                "responsePath": "data.buildings",
                "displayKey": "buildingName",
                "valueKey": "buildingId"
              }
            }
          },
          {
            "id": "DECORING_LOAD",
            "component": "field",
            "fieldType": "number",
            "label": "De-Coring Load",
            "unit": "kg",
            "style": {
              "colSpan": {
                "xs": 12,
                "sm": 6,
                "md": 4
              },
              "width": "180px"
            }
          },
          {
            "id": "DECORING_VISUAL_OBSERVATION",
            "component": "field",
            "fieldType": "textarea",
            "label": "Visual Observations",
            "style": {
              "colSpan": {
                "xs": 12,
                "sm": 12,
                "md": 12
              },
              "flex": "1 1 100%"
            }
          }
        ]
      }
    ]
  }
}
