{
  "schemaVersion": "1.0",
  "motorStage": 1,
  "schemaType": "CASTING",
  "functionality": "CREATE_CASTING_FORM",
  "meta": {
    "title": "Casting Form",
    "description": "Casting process details for single motor"
  },
  "data": {
    "ui": {
      "layout": "accordion",
      "gap": "md",
      "sectionVariant": "card"
    },
    "context": {
      "motorStage": 1,
      "subDepartmentId": "{{subDepartmentId}}",
      "motorId": "{{motorId}}"
    },
    "sections": [
      {
        "id": "FINAL_ASSEMBLY_DETAILS",
        "title": "Section A: Final Assembly Details",
        "ui": {
          "variant": "card",
          "padding": "md"
        },
        "children": [
          {
            "type": "display",
            "id": "FINAL_ASSEMBLY_STAGE_LABEL",
            "displayType": "description",
            "label": "For Project A Stage - I"
          },
          {
            "type": "section",
            "id": "motorCasing",
            "title": "Rocket Motor Casing {index}",
            "repeat": {
              "defaultCount": 1,
              "min": 1,
              "max": 10,
              "allowAdd": true,
              "allowDelete": true,
              "label": "Rocket Motor Casing {index}"
            },
            "children": [
              {
                "type": "table",
                "id": "MANDREL_MEASUREMENTS",
                "label": "Distance between centering top to mandrel top (mm)",
                "rows": {
                  "defaultCount": 3,
                  "allowAdd": true,
                  "allowDelete": true,
                  "autoIncrementKey": "srNo"
                },
                "columns": [
                  {
                    "type": "column",
                    "id": "srNo",
                    "fieldType": "serial",
                    "label": "Sr. No."
                  },
                  {
                    "type": "group",
                    "id": "MANDREL_DOME_A",
                    "label": "Mandrel rest on dome of motor (A)",
                    "columns": [
                      {
                        "type": "column",
                        "id": "A_MOCK",
                        "fieldType": "number",
                        "label": "Mock assy.",
                        "unit": "mm"
                      }
                    ]
                  },
                  {
                    "type": "group",
                    "id": "BOTTOM_CUP_B",
                    "label": "Mandrel rest on bottom cup (with Teflon sleeve) (B)",
                    "columns": [
                      {
                        "type": "column",
                        "id": "B_MOCK",
                        "fieldType": "number",
                        "label": "Mock assy.",
                        "unit": "mm"
                      },
                      {
                        "type": "column",
                        "id": "B_FINAL",
                        "fieldType": "number",
                        "label": "Final assy.",
                        "unit": "mm"
                      }
                    ]
                  },
                  {
                    "type": "group",
                    "id": "DIFFERENCE_C",
                    "label": "Difference C=(A-B)",
                    "columns": [
                      {
                        "type": "column",
                        "id": "C_MOCK",
                        "fieldType": "formula",
                        "label": "Mock assy.",
                        "formula": {
                          "expression": "A_MOCK-B_MOCK",
                          "dependencies": ["A_MOCK", "B_MOCK"]
                        },
                        "readonly": true
                      },
                      {
                        "type": "column",
                        "id": "C_FINAL",
                        "fieldType": "formula",
                        "label": "Final assy.",
                        "formula": {
                          "expression": "A_MOCK-B_FINAL",
                          "dependencies": ["A_MOCK", "B_FINAL"]
                        },
                        "readonly": true
                      }
                    ]
                  },
                  {
                    "type": "column",
                    "id": "BELLOWS_THICKNESS_D",
                    "fieldType": "number",
                    "label": "Bellow thickness (D)",
                    "unit": "mm"
                  },
                  {
                    "type": "group",
                    "id": "MANDREL_LIFT_E",
                    "label": "Mandrel lift E=(C-D)",
                    "columns": [
                      {
                        "type": "column",
                        "id": "E_MOCK",
                        "fieldType": "formula",
                        "label": "Mock assy.",
                        "formula": {
                          "expression": "C_MOCK-BELLOWS_THICKNESS_D",
                          "dependencies": ["C_MOCK", "BELLOWS_THICKNESS_D"]
                        },
                        "readonly": true
                      },
                      {
                        "type": "column",
                        "id": "E_FINAL",
                        "fieldType": "formula",
                        "label": "Final assy.",
                        "formula": {
                          "expression": "C_FINAL-BELLOWS_THICKNESS_D",
                          "dependencies": ["C_FINAL", "BELLOWS_THICKNESS_D"]
                        },
                        "readonly": true
                      }
                    ]
                  }
                ]
              },
              {
                "type": "table",
                "id": "FEED_PIPE_DISTANCE",
                "label": "Measurement of distance between feed pipe & cone apex",
                "rows": {
                  "defaultCount": 1,
                  "allowAdd": false,
                  "allowDelete": false
                },
                "columns": [
                  {
                    "type": "column",
                    "id": "READING_1",
                    "fieldType": "number",
                    "label": "Reading 1",
                    "unit": "mm"
                  },
                  {
                    "type": "column",
                    "id": "READING_2",
                    "fieldType": "number",
                    "label": "Reading 2",
                    "unit": "mm"
                  }
                ]
              },
              {
                "type": "field",
                "id": "EMPTY_MOTOR_WEIGHT",
                "fieldType": "number",
                "label": "Weight of assembled empty motor casing",
                "unit": "kg"
              },
              {
                "type": "field",
                "id": "MOTOR_ID",
                "fieldType": "dropdown",
                "label": "Motor Id",
                "dataSource": {
                  "type": "api",
                  "api": {
                    "endpoint": "APPROVED_MOTORS_LIST",
                    "method": "POST",
                    "requestBody": {
                      "subDepartmentId": "{{subDepartmentId}}",
                      "batchId": "{{batchId}}"
                    },
                    "responsePath": "data",
                    "displayKey": "motorId",
                    "valueKey": "motorId"
                  }
                }
              }
            ]
          }
        ]
      },
      {
        "id": "CASTING_PROCESS",
        "title": "Section B: Casting Process",
        "children": [
          {
            "type": "group",
            "id": "FINAL_MIX_DETAILS",
            "label": "Final Mix {index}",
            "repeat": {
              "defaultCount": "{{finalMixCount}}",
              "min": "{{finalMixCount}}",
              "max": "{{finalMixCount}}",
              "allowAdd": false,
              "allowDelete": false,
              "label": "Final Mix {index}"
            },
            "children": [
              {
                "type": "table",
                "id": "BOWL_DETAILS",
                "label": "Bowl Details",
                "rows": {
                  "defaultCount": 1,
                  "allowAdd": true,
                  "allowDelete": true
                },
                "columns": [
                  {
                    "type": "column",
                    "id": "BOWL_ID",
                    "fieldType": "text",
                    "label": "Bowl Id"
                  },
                  {
                    "type": "column",
                    "id": "BOWL_RECEIPT_TIME",
                    "fieldType": "time",
                    "label": "Bowl Receipt Time"
                  },
                  {
                    "type": "column",
                    "id": "INITIAL_WEIGHT",
                    "fieldType": "number",
                    "label": "Initial Weight"
                  },
                  {
                    "type": "column",
                    "id": "FINAL_WEIGHT",
                    "fieldType": "number",
                    "label": "Final Weight"
                  },
                  {
                    "type": "column",
                    "id": "INITIAL_SLURRY_DEPTH",
                    "fieldType": "number",
                    "label": "Initial Slurry Depth"
                  },
                  {
                    "type": "column",
                    "id": "DC_OPEN_TIME",
                    "fieldType": "time",
                    "label": "Bowl D/C Valve Opening Time"
                  },
                  {
                    "type": "column",
                    "id": "DC_CLOSE_TIME",
                    "fieldType": "time",
                    "label": "Bowl D/C Valve Closing Time"
                  }
                ]
              }
            ]
          },
          {
            "type": "table",
            "id": "CASTING_FROM_BOWL_DETAILS",
            "label": "Casting From Bowl Details",
            "rows": {
              "defaultCount": 1,
              "allowAdd": true,
              "allowDelete": true
            },
            "columns": [
              {
                "type": "column",
                "id": "BOWL_ID",
                "fieldType": "text",
                "label": "Bowl Id"
              },
              {
                "type": "column",
                "id": "TIME_INTERVAL",
                "fieldType": "number",
                "label": "Time Interval",
                "unit": "hrs"
              },
              {
                "type": "column",
                "id": "RH",
                "fieldType": "number",
                "label": "RH",
                "unit": "%"
              },
              {
                "type": "column",
                "id": "VISCOSITY",
                "fieldType": "number",
                "label": "Viscosity",
                "unit": "Poise"
              },
              {
                "type": "column",
                "id": "MOTOR_ID",
                "fieldType": "text",
                "label": "Motor Id No."
              },
              {
                "type": "column",
                "id": "SLURRY_DEPTH",
                "fieldType": "number",
                "label": "Slurry Depth",
                "unit": "cm"
              },
              {
                "type": "column",
                "id": "VACUUM_LEVEL",
                "fieldType": "number",
                "label": "Vacuum Level",
                "unit": "torr"
              }
            ]
          }
        ]
      },
      {
        "id": "POST_CAST_OPERATIONS",
        "title": "Section D: Post Cast Operations",
        "children": [
          {
            "type": "table",
            "id": "POST_CAST_TABLE",
            "rows": {
              "defaultCount": 6,
              "allowAdd": false,
              "allowDelete": false,
              "presetRows": [
                { "readonly": true, "ACTIVITY": "Soaking Time" },
                { "readonly": true, "ACTIVITY": "Time of removal from pit" },
                { "readonly": true, "ACTIVITY": "Fixtures assembled for curing" },
                { "readonly": true, "ACTIVITY": "Pressure sensor details (If applicable)" },
                { "readonly": true, "ACTIVITY": "Initial pressure reading (If applicable)" },
                { "readonly": true, "ACTIVITY": "Time of dispatch to curing station" }
              ]
            },
            "columns": [
              {
                "type": "column",
                "id": "ACTIVITY",
                "fieldType": "static",
                "label": "Activity",
                "readonly": true
              },
              {
                "type": "column",
                "id": "MOTOR_ID",
                "fieldType": "text",
                "label": "Motor Id No."
              }
            ]
          }
        ]
      }
    ]
  }
}
